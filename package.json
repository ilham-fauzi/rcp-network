{
  "name": "vpn-client",
  "version": "1.0.0",
  "description": "VPN Client Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "electron .",
    "electron-dev": "ELECTRON_IS_DEV=1 electron .",
    "dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 -t 60000 && ELECTRON_IS_DEV=1 electron .\"",
    "dev:electron": "wait-on http://localhost:3000 && ELECTRON_IS_DEV=1 electron .",
    "build-electron": "npm run build && electron-builder",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "electron": "^27.0.0",
    "keytar": "^7.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
